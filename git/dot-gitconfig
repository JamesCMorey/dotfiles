[user]
    name = James C. Morey
    email = jmorey551@gmail.com

[core]
    editor = nvim
    preloadindex = true
    excludesfile = ~/.gitignore_global
    autocrlf = input

[color]
    ui = auto

[alias]
    st = status --short
    co = checkout
    br = branch
    cm = commit
    amend = commit --amend
    lg = log --oneline --graph --decorate --all
    df = diff
    undo = reset --soft HEAD~1
    unstage = reset HEAD --

[merge]
    conflictstyle = diff3

[init]
    defaultBranch = main

[help]
    autocorrect = 1

[gc]
    auto = 256

# Remove after completing CS 61B
[pull]
    rebase = false
